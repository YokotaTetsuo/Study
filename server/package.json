{
  "name": "@pdf-review/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "tsx watch --env-file=../.env src/infrastructure/main.ts",
    "start": "tsx --env-file=../.env src/infrastructure/main.ts",
    "typecheck": "tsc -b",
    "build": "tsc -b",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "devDependencies": {
    "drizzle-kit": "0.31.10",
    "tsx": "^4.22.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@hono/node-server": "^1.19.14",
    "@hono/zod-openapi": "^0.18.4",
    "@node-rs/argon2": "^2.0.2",
    "@pdf-review/shared": "workspace:*",
    "dayjs": "^1.11.20",
    "drizzle-orm": "0.45.2",
    "hono": "^4.12.19",
    "postgres": "3.4.9",
    "ulid": "3.0.2",
    "zod": "^3.25.76"
  }
}

# server 設定。`cp .env.example .env` でデフォルトのまま動作する。

# PostgreSQL（docker compose の postgres サービス）
DB_HOST=localhost
DB_PORT=5432
DB_USER=pdfreview
DB_PASSWORD=pdfreview
DB_NAME=pdfreview

# API サーバーポート
PORT=3000

# 実行環境（development|test|production）。production で Cookie を Secure 化。
NODE_ENV=development

# Cookie 認証で許可するブラウザ Origin（CORS、非ワイルドカード）
CLIENT_ORIGIN=http://localhost:5173

# client が呼ぶ API ベース URL（PORT を変える場合はここも合わせる）
VITE_API_BASE=http://localhost:3000

# S3 互換ストレージ（Phase 3 で利用）
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=pdfreview
S3_ACCESS_KEY_ID=pdfreview
S3_SECRET_ACCESS_KEY=pdfreview
S3_FORCE_PATH_STYLE=true

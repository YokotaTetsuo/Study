{
  "name": "pdf-review",
  "version": "0.0.0",
  "private": true,
  "description": "PDF をバージョン管理し、版にコメント・承認フローを通すマルチユーザー Web アプリ",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "echo 'dev は Phase 0 PR 0.4 で server+client を配線します' && exit 0",
    "typecheck": "tsc -b",
    "build": "tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "depcruise": "dependency-cruise --config .dependency-cruiser.js server/src client/src shared/src infra/src",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/node": "^24.12.4",
    "@vitest/coverage-v8": "^3.0.5",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "jiti": "^2.7.0",
    "prettier": "^3.8.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.39.0",
    "vitest": "^3.0.5"
  }
}
